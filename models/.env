# 환경 설정 파일
# 이 파일은 모델 테스트에 필요한 경로와 설정 값을 정의합니다.
# 각 변수는 test_model.py 및 check_model_performance.py에서 사용됩니다.

# MODEL_PATH: 학습된 모델 파일 경로
# DATA_YAML_PATH: 데이터셋 설정 파일 경로
# IMG_SIZE: 입력 이미지 크기
# CONF_THRESHOLD: 신뢰도 임계값
# IMAGE_PATH: 테스트할 이미지 경로
# OUTPUT_DIR: 결과 이미지 저장 디렉토리

# 모델 및 데이터 경로 설정
DATA_YAML_PATH=../data.yaml                                                                                           
CONF_THRESHOLD=0.5                                                           
OUTPUT_DIR=image/output                                                 

MODEL_PATH=model_version/best_640nano.pt  
IMAGE_PATH=image/test4.jpg  